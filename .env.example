# Pure Quant Trading System - Environment Configuration
# Copy this to .env and fill in the values

# Existing Settings
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
GEMINI_API_KEY=your_gemini_api_key

# --- SECURITY UPGRADE (V22.1) ---

# JWT Secret for signed sessions (Required for persistence)
# Generate one with: openssl rand -hex 32
JWT_SECRET=your_32_byte_hex_secret

# Admin Credentials (Required for login)
# If not set, default admin/admin123 will be initialized
ADMIN_USER=admin
ADMIN_PASS=your_strong_password_here

# Restricted CORS Origins (Comma-separated)
# Only these domains will be allowed to access the API
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# --- MT5 AUTO-TRADING (MetaAPI linux-compatible bridge) ---
# Sign up free at https://metaapi.cloud
METAAPI_TOKEN=your_metaapi_token_here
METAAPI_ACCOUNT_ID=your_metaapi_account_id_here

# Trading Control
MT5_AUTO_TRADE=true
MT5_PAPER_MODE=true

# Cent Account Suffix (Important for brokers like HFM)
# e.g., if HFM symbols are EURUSDc, set this to "c". Leave empty for standard accounts.
MT5_SYMBOL_SUFFIX=c
